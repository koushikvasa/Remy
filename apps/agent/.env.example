# Agent server (Railway) — see REMY_SPEC.md §13
# LLM provider (all calls go through src/model.ts callModel())
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio (account creds; TWILIO_FROM_NUMBER places the P6 coordinator callout)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+16625478393

# Supabase (agent uses the service role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public host for the TwiML wss:// URL — BARE host, no scheme (Railway host or ngrok)
PUBLIC_HOST=

# HTTP port
PORT=8080

# Voice / call behavior (optional)
# Inbound call voice (ConversationRelay). Default provider ElevenLabs.
REMY_TTS_PROVIDER=ElevenLabs
# REMY_VOICE: ElevenLabs voice id (default "Matilda" XrExE9yKIg1WjnnlVkGX, warm female).
# Supports id, id-model, and id-speed_stability_similarity forms.
REMY_VOICE=
# If ElevenLabs isn't enabled on the account, switch to Google's premium voice:
#   REMY_TTS_PROVIDER=Google
#   REMY_VOICE=en-US-Journey-O          # (or en-US-Chirp3-HD-Aoede)
#
# Outbound-leg voice for TwiML <Say> (coordinator/source calls). <Say> does NOT
# support ElevenLabs — use a warm Amazon Polly / Google neural voice.
REMY_SAY_VOICE=Polly.Joanna-Neural
#   alt: Polly.Danielle-Generative, Google.en-US-Chirp3-HD-Aoede
#
# REMY_ECHO=1  → WS echoes instead of running the brain (P1 demo fallback)
REMY_ECHO=
# REMY_AUTO_END=1 → hang up after the closing line (tokens-played + delay fallback)
REMY_AUTO_END=
