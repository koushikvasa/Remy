# Agent server (Railway) — see REMY_SPEC.md §13
# LLM provider (all calls go through src/model.ts callModel())
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Supabase (agent uses the service role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public host for the TwiML wss:// URL (Railway host or ngrok)
PUBLIC_HOST=

# HTTP port
PORT=8080
